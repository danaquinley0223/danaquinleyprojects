{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "danaquinleyprojects",
  "main": "worker.js",
  "compatibility_date": "2026-06-10",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
